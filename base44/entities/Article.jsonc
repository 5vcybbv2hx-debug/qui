{
  "name": "Article",
  "type": "object",
  "properties": {
    "barcode": {
      "type": "string",
      "description": "Barcode/EAN"
    },
    "qr_code": {
      "type": "string",
      "description": "QR-Code (optional, f\u00fcr interne Kennzeichnung)"
    },
    "name": {
      "type": "string",
      "description": "Artikelname"
    },
    "manufacturer": {
      "type": "string",
      "description": "Hersteller / Marke (optional)"
    },
    "category": {
      "type": "string",
      "description": "Kategorie"
    },
    "suppliers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Liste der Lieferantennamen (R\u00fcckw\u00e4rtskompatibilit\u00e4t)"
    },
    "supplier_details": {
      "type": "array",
      "description": "Lieferanten mit Preisen und Details",
      "items": {
        "type": "object",
        "properties": {
          "supplier_name": {
            "type": "string"
          },
          "purchase_price": {
            "type": "number"
          },
          "article_number": {
            "type": "string"
          },
          "packaging_info": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "is_primary": {
            "type": "boolean"
          }
        }
      }
    },
    "content_unit": {
      "type": "string",
      "enum": [
        "l",
        "ml",
        "kg",
        "g",
        "St\u00fcck"
      ],
      "default": "St\u00fcck",
      "description": "Einheit des Inhalts"
    },
    "content_amount": {
      "type": "number",
      "description": "Inhaltsmenge (z.B. 0.7 f\u00fcr 0,7L Flasche)"
    },
    "purchase_price": {
      "type": "number",
      "description": "Einkaufspreis pro Einheit (Hauptlieferant)"
    },
    "price_per_liter": {
      "type": "number",
      "description": "Umgerechneter Preis pro Liter/kg (automatisch berechnet)"
    },
    "current_stock": {
      "type": "number",
      "description": "Aktueller Bestand"
    },
    "min_stock": {
      "type": "number",
      "description": "Mindestbestand"
    },
    "shelf_id": {
      "type": "string",
      "description": "Regal-ID (z.B. A1, B2, C3)"
    },
    "storage_location": {
      "type": "string",
      "description": "Lagerort (z.B. Keller, K\u00fchlraum)"
    },
    "image_url": {
      "type": "string",
      "description": "Bild-URL"
    },
    "allergens": {
      "type": "string",
      "description": "Allergene (Freitext, Legacy)"
    },
    "allergens_list": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Allergene (strukturiert)"
    },
    "additives": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Zusatzstoffe"
    },
    "notes": {
      "type": "string",
      "description": "Notizen"
    },
    "order": {
      "type": "number",
      "description": "Sortierreihenfolge innerhalb der Kategorie"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Aktiv"
    }
  },
  "required": [
    "name"
  ]
}