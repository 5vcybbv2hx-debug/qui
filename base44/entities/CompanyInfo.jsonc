{
  "name": "CompanyInfo",
  "type": "object",
  "properties": {
    "company_name": {
      "type": "string",
      "description": "Firmenname (Pflichtfeld)"
    },
    "street": {
      "type": "string",
      "description": "Straße und Hausnummer"
    },
    "postal_code": {
      "type": "string",
      "description": "Postleitzahl"
    },
    "city": {
      "type": "string",
      "description": "Stadt"
    },
    "country": {
      "type": "string",
      "description": "Land",
      "default": "Deutschland"
    },
    "email": {
      "type": "string",
      "description": "Kontakt-E-Mail"
    },
    "phone": {
      "type": "string",
      "description": "Telefonnummer"
    },
    "website": {
      "type": "string",
      "description": "Webseite"
    },
    "description": {
      "type": "string",
      "description": "Kurzbeschreibung"
    },
    "opening_hours": {
      "type": "string",
      "description": "Öffnungszeiten (JSON)"
    },
    "logo_url": {
      "type": "string",
      "description": "URL des Firmenlogos"
    },
    "tax_id": {
      "type": "string",
      "description": "Steuernummer"
    },
    "vat_id": {
      "type": "string",
      "description": "USt-IdNr."
    },
    "bank_name": {
      "type": "string",
      "description": "Kreditinstitut"
    },
    "iban": {
      "type": "string",
      "description": "IBAN"
    },
    "bic": {
      "type": "string",
      "description": "BIC"
    },
    "owner_name": {
      "type": "string",
      "description": "Name des Betreibers/Verantwortlichen"
    },
    "legal_form": {
      "type": "string",
      "enum": [
        "Einzelunternehmer",
        "GbR",
        "oHG",
        "KG",
        "GmbH",
        "AG",
        "Ltd.",
        "Sonstiges"
      ],
      "description": "Rechtsform"
    },
    "data_protection_contact": {
      "type": "string",
      "description": "Datenschutz-Kontakt (optional, falls abweichend)"
    },
    "datenschutz_version": {
      "type": "string",
      "default": "1.0",
      "description": "Versionsnummer der Datenschutzerklärung"
    },
    "agb_version": {
      "type": "string",
      "default": "1.0",
      "description": "Versionsnummer der AGB"
    },
    "impressum_version": {
      "type": "string",
      "default": "1.0",
      "description": "Versionsnummer des Impressums"
    },
    "setup_complete": {
      "type": "boolean",
      "default": false,
      "description": "Ist das Legal-Setup abgeschlossen?"
    },
    "payroll_email": {
      "type": "string",
      "description": "Email-Adresse für Lohnbüro-Reports"
    },
    "datev_beraternummer": {
      "type": "string",
      "description": "DATEV Beraternummer"
    },
    "datev_mandantennummer": {
      "type": "string",
      "description": "DATEV Mandantennummer"
    },
    "whatsapp_group_link": {
      "type": "string",
      "description": "WhatsApp-Gruppenlink für das Team"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "Letzte Aktualisierung"
    },
    "module_states": {
      "type": "string",
      "description": "JSON-String mit Aktivierungsstatus der Module (ModuleCenter)"
    }
  },
  "required": [
    "company_name"
  ]
}