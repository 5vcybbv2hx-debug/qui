{
  "name": "Furniture",
  "type": "object",
  "properties": {
    "area_id": {
      "type": "string",
      "description": "ID des Bereichs"
    },
    "area_name": {
      "type": "string",
      "description": "Name des Bereichs (Denormalisierung)"
    },
    "name": {
      "type": "string",
      "description": "Name des M\u00f6bels (z.B. K\u00fchlschrank Bar, Regal Links)"
    },
    "type": {
      "type": "string",
      "enum": [
        "Regal",
        "Schrank",
        "K\u00fchlschrank",
        "Tiefk\u00fchlschrank",
        "Schubladenbox",
        "Tisch",
        "Kiste",
        "Sonstiges"
      ],
      "description": "M\u00f6beltyp"
    },
    "notes": {
      "type": "string",
      "description": "Optionale Beschreibung"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "M\u00f6bel aktiv"
    },
    "sort_order": {
      "type": "number",
      "description": "Sortierreihenfolge im Bereich"
    }
  },
  "required": [
    "area_id",
    "name",
    "type"
  ]
}