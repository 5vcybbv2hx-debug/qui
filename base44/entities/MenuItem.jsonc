{
  "name": "MenuItem",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name des Getr\u00e4nks"
    },
    "category": {
      "type": "string",
      "enum": [
        "Bier",
        "Wein",
        "Sekt & Champagner",
        "Spirituosen",
        "Longdrinks",
        "Cocktails",
        "Shots",
        "Softdrinks",
        "Hei\u00dfgetr\u00e4nke",
        "Moonshiner-Cocktails"
      ],
      "description": "Kategorie"
    },
    "subcategory": {
      "type": "string",
      "description": "Unterkategorie (z.B. Rum, Vodka, IPA)"
    },
    "description": {
      "type": "string",
      "description": "Beschreibung/Zutaten"
    },
    "price": {
      "type": "number",
      "description": "Preis in Euro"
    },
    "size": {
      "type": "string",
      "description": "Gr\u00f6\u00dfe (z.B. 0,3l, 4cl, 0,1l)"
    },
    "purchase_price": {
      "type": "number",
      "description": "Einkaufspreis (manuell oder berechnet)"
    },
    "use_recipe_calculation": {
      "type": "boolean",
      "default": false,
      "description": "EK automatisch aus Rezept berechnen"
    },
    "linked_recipe_id": {
      "type": "string",
      "description": "Verkn\u00fcpftes Rezept f\u00fcr automatische Berechnung"
    },
    "is_available": {
      "type": "boolean",
      "default": true,
      "description": "Aktuell verf\u00fcgbar"
    },
    "is_seasonal": {
      "type": "boolean",
      "default": false,
      "description": "Saisonales Angebot"
    },
    "is_special": {
      "type": "boolean",
      "default": false,
      "description": "Tagesangebot/Special"
    },
    "order_position": {
      "type": "number",
      "description": "Reihenfolge in der Karte"
    },
    "allergens_list": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Allergene (strukturiert)"
    },
    "additives": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Zusatzstoffe"
    },
    "alcohol_content": {
      "type": "number",
      "description": "Alkoholgehalt in %"
    },
    "image_url": {
      "type": "string",
      "description": "Bild-URL"
    },
    "linked_article_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs der verkn\u00fcpften Artikel (mehrere m\u00f6glich)"
    }
  },
  "required": [
    "name",
    "category",
    "price"
  ]
}