{
  "name": "OnboardingTask",
  "type": "object",
  "properties": {
    "category": {
      "type": "string",
      "description": "Kategorie (z.B. Kasse und EC Geräte)"
    },
    "category_icon": {
      "type": "string",
      "description": "Icon für die Kategorie (Emoji)"
    },
    "category_color": {
      "type": "string",
      "description": "Farbklasse für die Kategorie (z.B. blue, amber)"
    },
    "title": {
      "type": "string",
      "description": "Aufgabentitel"
    },
    "description": {
      "type": "string",
      "description": "Kurze Beschreibung"
    },
    "instructions": {
      "type": "string",
      "description": "Ausführliche Schritt-für-Schritt-Anleitung (optional, ausklappbar)"
    },
    "order": {
      "type": "number",
      "description": "Sortierreihenfolge innerhalb der Kategorie"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Aktiv/deaktiviert"
    }
  },
  "required": [
    "category",
    "title"
  ]
}
