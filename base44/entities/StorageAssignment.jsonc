{
  "name": "StorageAssignment",
  "type": "object",
  "properties": {
    "article_id": {
      "type": "string",
      "description": "ID des Artikels (aus Article-Entity)"
    },
    "article_name": {
      "type": "string",
      "description": "Name des Artikels (f\u00fcr schnellen Zugriff)"
    },
    "storage_slot_id": {
      "type": "string",
      "description": "ID des Lagerplatzes (StorageSlot)"
    },
    "slot_full_name": {
      "type": "string",
      "description": "Full Name des Lagerplatzes"
    },
    "quantity": {
      "type": "number",
      "description": "Aktuelle Menge am Lagerplatz"
    },
    "min_stock": {
      "type": "number",
      "description": "Mindestbestand"
    },
    "max_stock": {
      "type": "number",
      "description": "Maximaler Bestand"
    },
    "unit": {
      "type": "string",
      "description": "Einheit (St\u00fcck, Liter, kg, etc.)"
    },
    "notes": {
      "type": "string",
      "description": "Notizen zur Lagerung"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Zuordnung aktiv"
    }
  },
  "required": [
    "article_id",
    "storage_slot_id"
  ]
}